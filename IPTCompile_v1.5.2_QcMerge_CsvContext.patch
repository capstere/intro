+        if ($parts -notcontains $Flag) { $parts += $Flag }
+        try { $Row.RuleFlags = ($parts -join '|') }
+        catch { try { $Row | Add-Member -NotePropertyName 'RuleFlags' -NotePropertyValue ($parts -join '|') -Force } catch {} }
+    }
+
+    function _MergeRemoveRuleFlag {
+        param([object]$Row, [string]$Flag)
+        if (-not $Row -or [string]::IsNullOrWhiteSpace(($Flag + ''))) { return }
+        $parts = @(($Row.RuleFlags + '') -split '\|' | ForEach-Object { ($_ + '').Trim() } | Where-Object { $_ -and ($_ -ine $Flag) })
+        try { $Row.RuleFlags = ($parts -join '|') }
+        catch { try { $Row | Add-Member -NotePropertyName 'RuleFlags' -NotePropertyValue ($parts -join '|') -Force } catch {} }
+    }
+
+    $rows = @()
+    if ($PrimaryResult -and $PrimaryResult.Rows) { $rows += @($PrimaryResult.Rows) }
+    if ($ResampleResult -and $ResampleResult.Rows) { $rows += @($ResampleResult.Rows) }
+
+    if ($rows.Count -eq 0) {
+        return [pscustomobject]@{
+            Rows=@()
+            Summary=[pscustomobject]@{ Total=0; ObservedCounts=@{}; DeviationCounts=@{}; RetestYes=0; MinorFunctionalError=0; InstrumentError=0; DelamCount=0; ReplacementCount=0 }
+            TopDeviations=@()
+            QC=[pscustomobject]@{}
+        }
+    }
+
+    # Flaggor som beror på hela datamängdens fördelning räknas om från grunden.
+    # Annars kan Primary och Resample var för sig ge ett annat resultat än den kombinerade körningen.
+    foreach ($r in $rows) {
+        foreach ($flagToReset in @('DQ_ASSAY_OUTLIER','DQ_ASSAYVER_OUTLIER','DQ_DUP_CARTSN','PREFIX_BAD','MODULE_ERR_HOTSPOT')) {
+            _MergeRemoveRuleFlag -Row $r -Flag $flagToReset
+        }
+    }
+
+    $combinedAssays = @($rows | ForEach-Object { (($_.Assay + '').Trim()) } | Where-Object { $_ } | Sort-Object -Unique)
+    if ($combinedAssays.Count -gt 1) {
+        $majorAssay = ''
+        try { $majorAssay = ($rows | Where-Object { (($_.Assay + '').Trim()) } | Group-Object Assay | Sort-Object Count -Descending | Select-Object -First 1).Name } catch {}
+        foreach ($r in $rows) {
+            $value = (($r.Assay + '').Trim())
+            if ($majorAssay -and $value -and $value -ne $majorAssay) { _MergeAppendRuleFlag -Row $r -Flag 'DQ_ASSAY_OUTLIER' }
+        }
+    }
+
+    $combinedVersions = @($rows | ForEach-Object { (($_.AssayVersion + '').Trim()) } | Where-Object { $_ } | Sort-Object -Unique)
+    if ($combinedVersions.Count -gt 1) {
+        $majorVersion = ''
+        try { $majorVersion = ($rows | Where-Object { (($_.AssayVersion + '').Trim()) } | Group-Object AssayVersion | Sort-Object Count -Descending | Select-Object -First 1).Name } catch {}
+        foreach ($r in $rows) {
+            $value = (($r.AssayVersion + '').Trim())
+            if ($majorVersion -and $value -and $value -ne $majorVersion) { _MergeAppendRuleFlag -Row $r -Flag 'DQ_ASSAYVER_OUTLIER' }
+        }
+    }
+
+    # Sample ID får upprepas mellan Primary och Resample, men Cartridge S/N ska vara unik
+    # över hela den kombinerade körningen.
+    $combinedDuplicateCartGroups = @($rows | Where-Object { (($_.CartridgeSN + '').Trim()) } | Group-Object CartridgeSN | Where-Object { $_.Count -gt 1 })
+    if ($combinedDuplicateCartGroups.Count -gt 0) {
+        $duplicateCartSet = @{}
+        foreach ($g in $combinedDuplicateCartGroups) { $duplicateCartSet[$g.Name] = $true }
+        foreach ($r in $rows) {
+            $cart = (($r.CartridgeSN + '').Trim())
+            if ($cart -and $duplicateCartSet.ContainsKey($cart)) { _MergeAppendRuleFlag -Row $r -Flag 'DQ_DUP_CARTSN' }
+        }
+    }
+
+    # Prefix-heuristiken ska baseras på hela körningen, inte på varje CSV separat.
+    $useStrictPrefix = $false
+    try {
+        $p0 = @($rows | Where-Object { (($_.SampleCode + '').Trim()) -eq '0' -and (($_.SamplePrefix + '').Trim()) })
+        $pP = @($rows | Where-Object { (($_.SampleCode + '').Trim()) -match '^[1-5]$' -and (($_.SamplePrefix + '').Trim()) })
+        $ok0 = @($p0 | Where-Object { (($_.SamplePrefix + '').Trim().ToUpperInvariant()) -eq 'NEG' }).Count
+        $okP = @($pP | Where-Object { (($_.SamplePrefix + '').Trim().ToUpperInvariant()) -eq 'POS' }).Count
+        $r0 = 0.0; $rP = 0.0
+        if ($p0.Count -gt 0) { $r0 = [double]$ok0 / [double]$p0.Count }
+        if ($pP.Count -gt 0) { $rP = [double]$okP / [double]$pP.Count }
+        if ($p0.Count -ge 3 -and $pP.Count -ge 3 -and $r0 -ge 0.80 -and $rP -ge 0.80) { $useStrictPrefix = $true }
+        elseif ($p0.Count -ge 10 -and $pP.Count -eq 0 -and $r0 -ge 0.90) { $useStrictPrefix = $true }
+        elseif ($pP.Count -ge 10 -and $p0.Count -eq 0 -and $rP -ge 0.90) { $useStrictPrefix = $true }
+    } catch { $useStrictPrefix = $false }
+
+    if ($useStrictPrefix) {
+        foreach ($r in $rows) {
+            $rowFlags = @(($r.RuleFlags + '') -split '\|' | ForEach-Object { ($_ + '').Trim() })
+            if ($rowFlags -contains 'DQ_ASSAY_OUTLIER' -or $rowFlags -contains 'DQ_ASSAYVER_OUTLIER') { continue }
+            $prefix = (($r.SamplePrefix + '').Trim().ToUpperInvariant())
+            $sampleCode = (($r.SampleCode + '').Trim())
+            if ($sampleCode -notmatch '^\d+$') { continue }
+            $sampleCodeNumber = 0
+            try { $sampleCodeNumber = [int]$sampleCode } catch { continue }
+            if ($sampleCodeNumber -eq 0 -and $prefix -and $prefix -ne 'NEG') { _MergeAppendRuleFlag -Row $r -Flag 'PREFIX_BAD' }
+            elseif ($sampleCodeNumber -ge 1 -and $sampleCodeNumber -le 5 -and $prefix -and $prefix -ne 'POS') { _MergeAppendRuleFlag -Row $r -Flag 'PREFIX_BAD' }
+        }
+    }
+
+    # Modulhotspots bedöms på hela körningen. Sample ID-dubbletter behålls däremot
+    # per källa eftersom samma Sample ID kan vara avsiktligt i Primary och Resample.
+    $hotModules = @{}
+    $byModErr = @($rows | Where-Object { (($_.ModuleSN + '').Trim()) -and (($_.ObservedCall + '').Trim().ToUpperInvariant() -eq 'ERROR') } | Group-Object ModuleSN)
+    foreach ($g in $byModErr) { if ($g.Count -ge 3) { $hotModules[$g.Name] = $g.Count } }
+    if ($hotModules.Count -gt 0) {
+        foreach ($r in $rows) {
+            $m = (($r.ModuleSN + '').Trim())
+            if ($m -and $hotModules.ContainsKey($m)) { _MergeAppendRuleFlag -Row $r -Flag 'MODULE_ERR_HOTSPOT' }
+        }
+    }
+
+    $summary = [pscustomobject]@{
+        Total = $rows.Count
+        ObservedCounts = @{}
+        DeviationCounts = @{}
+        RetestYes = 0
+        MinorFunctionalError = 0
+        InstrumentError = 0
+        DelamCount = 0
+        ReplacementCount = 0
+    }
+
+    foreach ($r in $rows) {
+        $obs = (($r.ObservedCall + '').Trim())
+        if (-not $summary.ObservedCounts.ContainsKey($obs)) { $summary.ObservedCounts[$obs] = 0 }
+        $summary.ObservedCounts[$obs] = [int]$summary.ObservedCounts[$obs] + 1
+
+        $dev = (($r.Deviation + '').Trim())
+        if (-not $summary.DeviationCounts.ContainsKey($dev)) { $summary.DeviationCounts[$dev] = 0 }
+        $summary.DeviationCounts[$dev] = [int]$summary.DeviationCounts[$dev] + 1
+
+        $rt = (($r.GeneratesRetest + '').Trim().ToUpperInvariant())
+        if ($rt -in @('YES','Y','TRUE','1')) { $summary.RetestYes++ }
+        try { if ([bool]$r.DelamPresent) { $summary.DelamCount++ } } catch {}
+        try { if ([int]$r.ReplacementLevel -ge 1) { $summary.ReplacementCount++ } } catch {}
+
+        if ($dev.ToUpperInvariant() -eq 'ERROR') {
+            $isKnown = $false
+            try { $isKnown = [bool]$r.IsKnownCode } catch {}
+            $isMtbInd = $false
+            try { if ((($r.Assay + '') -match '(?i)MTB') -and (($r.TestResult + '') -match '(?i)INDETERMINATE')) { $isMtbInd = $true } } catch {}
+            if ($isKnown -or $isMtbInd) { $summary.MinorFunctionalError++ }
+            else { $summary.InstrumentError++ }
+        }
+    }
+
+    $assays = @($rows | ForEach-Object { (($_.Assay + '').Trim()) } | Where-Object { $_ } | Sort-Object -Unique)
+    $versions = @($rows | ForEach-Object { (($_.AssayVersion + '').Trim()) } | Where-Object { $_ } | Sort-Object -Unique)
+    $lots = @($rows | ForEach-Object { (($_.ReagentLotId + '').Trim()) } | Where-Object { $_ } | Sort-Object -Unique)
+
+    $assayDistribution = @($rows | Where-Object { (($_.Assay + '').Trim()) } | Group-Object Assay | Sort-Object Name | ForEach-Object { [pscustomobject]@{ Value=$_.Name; Count=$_.Count } })
+    $versionDistribution = @($rows | Where-Object { (($_.AssayVersion + '').Trim()) } | Group-Object AssayVersion | Sort-Object Name | ForEach-Object { [pscustomobject]@{ Value=$_.Name; Count=$_.Count } })
+    $lotDistribution = @($rows | Where-Object { (($_.ReagentLotId + '').Trim()) } | Group-Object ReagentLotId | Sort-Object Name | ForEach-Object { [pscustomobject]@{ Value=$_.Name; Count=$_.Count } })
+
+    $dupSampleCount = 0
+    try { if ($PrimaryResult.QC) { $dupSampleCount += [int]$PrimaryResult.QC.DuplicateSampleIdCount } } catch {}
+    try { if ($ResampleResult.QC) { $dupSampleCount += [int]$ResampleResult.QC.DuplicateSampleIdCount } } catch {}
+    $dupCartCount = @($combinedDuplicateCartGroups).Count
+
+    $qc = [pscustomobject]@{
+        DistinctAssays = $assays
+        DistinctAssayVersions = $versions
+        DistinctReagentLots = $lots
+        AssayDistribution = $assayDistribution
+        AssayVersionDistribution = $versionDistribution
+        ReagentLotDistribution = $lotDistribution
+        DuplicateSampleIdCount = $dupSampleCount
+        DuplicateCartridgeSnCount = $dupCartCount
+        HotModuleCount = $hotModules.Count
+        DelamCount = @($rows | Where-Object { try { [bool]$_.DelamPresent } catch { $false } }).Count
+        ReplacementCount = @($rows | Where-Object { try { [int]$_.ReplacementLevel -ge 1 } catch { $false } }).Count
+        BadPrefixCount = @($rows | Where-Object { (($_.RuleFlags + '') -split '\|') -contains 'PREFIX_BAD' }).Count
+        BadRunNoCount = @($rows | Where-Object { (($_.RuleFlags + '') -split '\|') -contains 'RUNNO_BAD' }).Count
+    }
+
+    $assayList = $assays
+    $ttMatched = 0
+    $ttMissing = @()
+    $ttDetails = @()
+    foreach ($a in $assayList) {
+        $pol = $null
+        try { if ($RuleBank) { $pol = Get-TestTypePolicyForAssayCached -RuleBank $RuleBank -Assay $a } } catch {}
+        if ($pol) {
+            $ttMatched++
+            $pat = ((Get-RowField -Row $pol -FieldName 'AssayPattern') + '').Trim()
+            $allowed = ((Get-RowField -Row $pol -FieldName 'AllowedTestTypes') + '').Trim()
+            if (-not $allowed) { $allowed = ((Get-RowField -Row $pol -FieldName 'TestTypes') + '').Trim() }
+            $ttDetails += ($a + ' => ' + $allowed + ' (pattern=' + $pat + ')')
+        } else { $ttMissing += $a }
+    }
+
+    $sidTotal = @($rows | Where-Object { (($_.SampleId + '').Trim().Length -gt 0) }).Count
+    $sidOk = @($rows | Where-Object {
+        (($_.SampleId + '').Trim().Length -gt 0) -and
+        (($_.BagNo + '').Trim().Length -gt 0) -and
+        (($_.SampleCode + '').Trim().Length -gt 0) -and
+        (($_.RunNo + '').Trim().Length -gt 0) -and
+        (($_.RunSuffix + '').Trim().Length -gt 0)
+    }).Count
+    $snCovered = @($rows | Where-Object { (($_.SampleId + '').Trim().Length -gt 0) -and (($_.SampleNumOK + '').Trim().Length -gt 0) }).Count
+
+    $summary | Add-Member -NotePropertyName 'TestTypePolicyAssaysTotal' -NotePropertyValue $assayList.Count -Force
+    $summary | Add-Member -NotePropertyName 'TestTypePolicyAssaysMatched' -NotePropertyValue $ttMatched -Force
+    $summary | Add-Member -NotePropertyName 'TestTypePolicyAssaysMissing' -NotePropertyValue ($ttMissing -join ', ') -Force
+    $summary | Add-Member -NotePropertyName 'TestTypePolicyDetails' -NotePropertyValue $ttDetails -Force
+    $summary | Add-Member -NotePropertyName 'SampleIdParseTotal' -NotePropertyValue $sidTotal -Force
+    $summary | Add-Member -NotePropertyName 'SampleIdParseOk' -NotePropertyValue $sidOk -Force
+    $summary | Add-Member -NotePropertyName 'SampleNumberRuleTotal' -NotePropertyValue $sidTotal -Force
+    $summary | Add-Member -NotePropertyName 'SampleNumberRuleCovered' -NotePropertyValue $snCovered -Force
+
+    $top = @($rows | Where-Object { $_.Deviation -in @('FP','FN','ERROR','MISMATCH') } | Select-Object -First 50)
+    return [pscustomobject]@{ Rows=$rows; Summary=$summary; TopDeviations=$top; QC=$qc }
+}
