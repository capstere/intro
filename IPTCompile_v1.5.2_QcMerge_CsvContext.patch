+function Get-CsvStatsFromFieldRows {
+    param(
+        [object[]]$Rows,
+        [object[]]$Headers
+    )
+
+    $out = [ordered]@{
+        TestCount        = 0
+        DupCount         = 0
+        Duplicates       = @()
+        LspValues        = @()
+        LspOK            = $null
+        InstrumentByType = [ordered]@{}
+    }
+
+    $rows = @($Rows)
+    $headers = @($Headers)
+    if ($rows.Count -eq 0) { return [pscustomobject]$out }
+
+    $idxCart = Get-TestSummaryHeaderIndex -Headers $headers -Names @('Cartridge S/N') -DefaultIndex 3
+    $idxLsp  = Get-TestSummaryHeaderIndex -Headers $headers -Names @('Reagent Lot ID') -DefaultIndex 4
+    $idxIns  = Get-TestSummaryHeaderIndex -Headers $headers -Names @('Instrument S/N') -DefaultIndex 7
+
+    $cartSnList = New-Object System.Collections.Generic.List[string]
+    $lspList    = New-Object System.Collections.Generic.List[string]
+    $instrList  = New-Object System.Collections.Generic.List[string]
+
+    foreach ($fields0 in $rows) {
+        $fields = @(ConvertTo-IptFlatArray -Value $fields0)
+        if ($fields.Count -gt $idxCart) { [void]$cartSnList.Add((($fields[$idxCart] + '').Trim())) }
+        if ($fields.Count -gt $idxLsp)  { [void]$lspList.Add((($fields[$idxLsp] + '').Trim())) }
+        if ($fields.Count -gt $idxIns)  { [void]$instrList.Add((($fields[$idxIns] + '').Trim())) }
+    }
+
+    $cartSn = @($cartSnList.ToArray() | Where-Object { $_ })
+    $out.TestCount = $cartSn.Count
+    $dups = @($cartSn | Group-Object | Where-Object { $_.Count -gt 1 })
+    if ($dups.Count -gt 0) {
+        $out.DupCount = $dups.Count
+        $out.Duplicates = @($dups | ForEach-Object { "$($_.Name) x$($_.Count)" })
+    }
+
+    $lspClean = @($lspList.ToArray() | ForEach-Object {
+        $m = [regex]::Match(($_ + ''), '(?<!\d)(\d{5})(?!\d)')
+        if ($m.Success) { $m.Groups[1].Value }
+    } | Where-Object { $_ } | Select-Object -Unique)
+    $out.LspValues = $lspClean
+    if ($lspClean.Count -gt 0) { $out.LspOK = ($lspClean.Count -eq 1) }
+
+    $lut = @{ '6'='GeneXpert 6-color'; '10'='GeneXpert 10-color'; '16'='Infinity 48s'; 'Infinity'='Infinity 48s' }
+    foreach ($ins in @($instrList.ToArray() | Where-Object { $_ })) {
+        $t = if ($lut.ContainsKey($ins)) { $lut[$ins] } else { 'Unknown' }
+        if (-not $out.InstrumentByType.Contains($t)) { $out.InstrumentByType[$t] = 0 }
+        $out.InstrumentByType[$t] = [int]$out.InstrumentByType[$t] + 1
+    }
+
+    return [pscustomobject]$out
+}
+
+function New-TestSummaryCsvContext {
+    <#
+      Läser en Test Summary-CSV exakt en gång från disk och bygger all återanvändbar
+      runtime-data: profil, headers, fältrader, assay, statistik och instrumentserier.
+    #>
+    param(
+        [Parameter(Mandatory)][string]$Path,
+        [string]$SourceName
+    )
+
+    if (-not (Test-Path -LiteralPath $Path)) { return $null }
+
+    $lines = @(Read-TestSummaryCsvLines -Path $Path)
+    if ($lines.Count -eq 0) { return $null }
+
+    $profile = Get-TestSummaryCsvProfile -Path $Path -Lines $lines
+    if (-not $profile) { return $null }
+
+    $headers = @($profile.Headers)
+    $rowsList = New-Object System.Collections.Generic.List[object]
+    for ($i = [int]$profile.DataStartIndex; $i -lt $lines.Count; $i++) {
+        $line = $lines[$i]
+        if ([string]::IsNullOrWhiteSpace(($line + ''))) { continue }
+        $fields = @(ConvertTo-IptFlatArray -Value (ConvertTo-CsvFields -Line ($line + '') -Delimiter ''))
+        if (-not $fields -or (($fields -join '').Trim().Length -eq 0)) { continue }
+        [void]$rowsList.Add($fields)
+    }
+    $rows = @($rowsList.ToArray())
+
+    $assay = $null
+    $idxAssay = Get-TestSummaryHeaderIndex -Headers $headers -Names @('Assay') -DefaultIndex 0
+    foreach ($fields0 in $rows) {
+        $fields = @(ConvertTo-IptFlatArray -Value $fields0)
+        if ($fields.Count -le $idxAssay) { continue }
+        $candidate = (($fields[$idxAssay] + '').Trim())
+        if ($candidate -and $candidate -notmatch '^(?i)\s*assay\s*$') { $assay = $candidate; break }
+    }
+
+    $idxInstrument = Get-TestSummaryHeaderIndex -Headers $headers -Names @('Instrument S/N') -DefaultIndex 7
+    $instrumentSet = New-Object System.Collections.Generic.HashSet[string] ([System.StringComparer]::OrdinalIgnoreCase)
+    foreach ($fields0 in $rows) {
+        $fields = @(ConvertTo-IptFlatArray -Value $fields0)
+        if ($fields.Count -le $idxInstrument) { continue }
+        $value = (($fields[$idxInstrument] + '').Trim())
+        if ($value) { [void]$instrumentSet.Add($value) }
+    }
+
+    $displayName = (($SourceName + '').Trim())
+    if (-not $displayName) { $displayName = [System.IO.Path]::GetFileName($Path) }
+
+    return [pscustomobject]@{
+        Path              = $Path
+        SourceName        = $displayName
+        Lines             = $lines
+        Profile           = $profile
+        Headers           = $headers
+        Rows              = $rows
+        Assay             = $assay
+        Stats             = (Get-CsvStatsFromFieldRows -Rows $rows -Headers $headers)
+        InstrumentSerials = @($instrumentSet | Sort-Object)
+        DataRowCount      = $rows.Count
+    }
+}
